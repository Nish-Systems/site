  //. style="padding: 4rem 2rem; max-width: 900px; margin: 0 auto; font-family: 'JetBrains Mono', monospace;"
];
---

<Layout title="Niche Systems Consulting">
  
  <main style="padding: 4rem 2rem; max-width: 900px; margin: 0 auto; font-family: 'JetBrains Mono', monospace;">
    <h1 style="font-size: 2.5rem; margin-bottom: 0.5rem; text-align: center;">
      Our Team
    </h1>
    <p
      style="font-size: 1.2rem; line-height: 1.6; color: #555; text-align: center; margin-bottom: 4rem;"
    >
      <!-- We’re focused on building software that our clients can apply to
      cutting-edge research & real-world engineering. In addition to our core
      team, we have a diverse set of professional advisors who help us tackle
      the complex challenges our clients face. -->
      Our diverse set of engineers only consult where relevant. We regularly work on pure software projects which involve only our software engineers, but we also tackle projects that require expertise in other fields. In those cases, we bring in our advisors to consult on the project and help us build the best possible solution for our clients.
    </p>

    {/* Core Team Section */}
    <section style="margin-bottom: 5rem;">
      <h2
        style="font-size: 2rem; margin-bottom: 2rem; border-bottom: 2px solid #eaeaea; padding-bottom: 0.5rem;"
      >
        Core Team
      </h2>
      <div style="display: flex; flex-direction: column; gap: 2rem;">
        {
          coreTeam.map((member) => (
            <div style="display: flex; gap: 2rem; align-items: center; background: #fff; padding: 1.5rem; border: 1px solid #eaeaea; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.02);">
              <img
                src={member.imageUrl}
                alt={`Photo of ${member.name}`}
                style="width: 120px; height: 120px; border-radius: 50%; object-fit: cover; flex-shrink: 0;"
              />
              <div>
                <h3 style="margin: 0 0 0.25rem 0; font-size: 1.5rem; color: #111;">
                  {member.name}
                </h3>
                <p style="margin: 0 0 1rem 0; font-weight: 600; color: #0066cc;">
                  {member.title}
                </p>
                <p style="margin: 0; line-height: 1.6; color: #444;">
                  {member.description}
                </p>
              </div>
            </div>
          ))
        }
      </div>
    </section>

    {/* Advisors Section */}
    <section>
      <h2
        style="font-size: 2rem; margin-bottom: 2rem; border-bottom: 2px solid #eaeaea; padding-bottom: 0.5rem;"
      >
        Advisors
      </h2>
      <div style="display: flex; flex-direction: column; gap: 2rem;">
        {
          advisors.map((advisor) => (
            <div style="display: flex; gap: 2rem; align-items: center; background: #fafafa; padding: 1.5rem; border: 1px solid #eaeaea; border-radius: 12px;">
              <img
                src={advisor.imageUrl}
                alt={`Photo of ${advisor.name}`}
                style="width: 100px; height: 100px; border-radius: 50%; object-fit: cover; flex-shrink: 0;"
              />
              <div>
                <h3 style="margin: 0 0 0.25rem 0; font-size: 1.3rem; color: #111;">
                  {advisor.name}
                </h3>
                <p style="margin: 0 0 1rem 0; font-weight: 600; color: #0066cc;">
                  {advisor.title}
                </p>
                <p style="margin: 0; line-height: 1.6; color: #444;">
                  {advisor.description}
                </p>
              </div>
            </div>
          ))
        }
      </div>
    </section>
  </main>
</Layout>
