---
import Layout from "../layouts/Layout.astro";

interface TeamMember {
  name: string;
  title: string;
  description: string;
  imageUrl: string;
  link: string;
}

const coreTeam: TeamMember[] = [
  {
    name: "Rish Bector",
    title: "Founder & Software Systems Engineer",
    description:
      "Rish has over five years of professional experience and has spent over a decade writing software. He specializes in designing and building tools that solve the complex problems researchers and engineers face. He is currently also working on a Civil Engineering degree at Colorado School of Mines. Rish founded Niche Systems and is the primary consultant for our software-focused firm.",
    imageUrl: "/team/rishabh.png",
    link: "https://www.linkedin.com/in/bector",
  },
  {
    name: "Mitchell Jones",
    title: "Mechanical Engineer",
    description:
      "Mitchell is a mechanical engineer bringing a strong foundation in engineering principles to our projects. Applying rigorous mechanical principles, he ensures that our solutions operate flawlessly within the constraints of the physical world.",
    imageUrl: "/team/mitchell.png",
    link: "https://www.linkedin.com/in/mitchelljones411/",
  },
  {
    name: "Charlie Petry",
    title: "Project Manager",
    description:
      "Charlie is a project manager with almost a decade of experience helping teams deliver solutions on time and within budget.",
    imageUrl: "/team/charlie.png",
    link: "https://www.linkedin.com/in/charlie-petry/",
  },
];

const advisors: TeamMember[] = [
  // {
  //   name: "Chung-Ting Huang",
  //   title: "Software Architecture Advisor",
  //   description: "Chung-Ting has over 20 years of experience in software engineering and architecture, having led the design of scalable systems at the Fortune-500 level.",
  //   imageUrl: "https://ui-avatars.com/api/?name=Sarah+Jenkins&background=9C27B0&color=fff&size=150"
  // },
  {
    name: "Suresh Niraula",
    title: "Engineering Advisor",
    description:
      "Suresh Niraula, Ph.D., CLM, is a water quality scientist for the City of Arvada, Colorado, and served as the 2024 president of the Colorado Lake and Reservoir Management Association (CLRMA). His years of experience in water, civil and environmental engineering make him an invaluable advisor for our projects in those domains.",
    imageUrl: "/team/suresh.png",
    link: "https://www.linkedin.com/in/suresh-niraula-ph-d-clm-9064b315/",
  },
  // {
  //   name: "Alexandra Wallayce",
  //   title: "Civil Engineering Advisor",
  //   description: "Alexandra brings 15 years of civil engineering experience, helping us design and implement robust infrastructure solutions for our clients.",
  //   imageUrl: "https://ui-avatars.com/api/?name=Alexandra+Wallayce&background=FF9800&color=fff&size=150"
  // }

  //. style="padding: 4rem 2rem; max-width: 900px; margin: 0 auto; font-family: 'JetBrains Mono', monospace;"
];
---

<Layout title="Niche Systems Consulting">
  <main
    style="padding: 4rem 2rem; max-width: 900px; margin: 0 auto; font-family: 'JetBrains Mono', monospace;"
  >
    <h1 style="font-size: 2.5rem; margin-bottom: 0.5rem; text-align: center;">
      Our Team
    </h1>
    <p
      style="font-size: 1.2rem; line-height: 1.6; color: #555; text-align: center; margin-bottom: 4rem;"
    >
      Our diverse set of engineers only consult where relevant. We primarily work
      on pure software projects but if other areas of expertise are required, we will bring in the necessary experts to consult where relevant
      and help us build the best possible solution for our clients.
    </p>

    {/* Core Team Section */}
    <section style="margin-bottom: 5rem;">
      <h2
        style="font-size: 2rem; margin-bottom: 2rem; border-bottom: 2px solid #eaeaea; padding-bottom: 0.5rem;"
      >
        Core Team
      </h2>
      <div style="display: flex; flex-direction: column; gap: 2rem;">
        {
          coreTeam.map((member) => (
            <div style="display: flex; gap: 2rem; align-items: center; background: #fff; padding: 1.5rem; border: 1px solid #eaeaea; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.02);">
              <a href={member.link} style="display: inline-block; flex-shrink: 0;" target="_blank">
                <img
                  src={member.imageUrl}
                  alt={`Photo of ${member.name}`}
                  style="width: 120px; height: 120px; border-radius: 50%; object-fit: cover; flex-shrink: 0;"
                />
              </a>
              <div>
                <h3 style="margin: 0 0 0.25rem 0; font-size: 1.5rem; color: #111;">
                  <a href={member.link} style="color: inherit; text-decoration: none;" target="_blank">
                    {member.name}
                  </a>
                </h3>
                <p style="margin: 0 0 1rem 0; font-weight: 600; color: #0066cc;">
                  {member.title}
                </p>
                <p style="margin: 0; line-height: 1.6; color: #444;">
                  {member.description}
                </p>
              </div>
            </div>
          ))
        }
      </div>
    </section>

    {/* Advisors Section */}
    <section>
      <h2
        style="font-size: 2rem; margin-bottom: 2rem; border-bottom: 2px solid #eaeaea; padding-bottom: 0.5rem;"
      >
        Advisors
      </h2>
      <div style="display: flex; flex-direction: column; gap: 2rem;">
        {
          advisors.map((advisor) => (
            <div style="display: flex; gap: 2rem; align-items: center; background: #fafafa; padding: 1.5rem; border: 1px solid #eaeaea; border-radius: 12px;">
              <a href={advisor.link} style="display: inline-block; flex-shrink: 0;">
                <img
                  src={advisor.imageUrl}
                  alt={`Photo of ${advisor.name}`}
                  style="width: 100px; height: 100px; border-radius: 50%; object-fit: cover; flex-shrink: 0;"
                />
              </a>
              <div>
                <h3 style="margin: 0 0 0.25rem 0; font-size: 1.3rem; color: #111;">
                  <a href={advisor.link} style="color: inherit; text-decoration: none;">
                    {advisor.name}
                  </a>
                </h3>
                <p style="margin: 0 0 1rem 0; font-weight: 600; color: #0066cc;">
                  {advisor.title}
                </p>
                <p style="margin: 0; line-height: 1.6; color: #444;">
                  {advisor.description}
                </p>
              </div>
            </div>
          ))
        }
      </div>
    </section>
  </main>
</Layout>
